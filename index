<script>
document.querySelectorAll('.day-head').forEach(head => {
  head.addEventListener('click', () => {
    head.parentElement.classList.toggle('open');
    const t = head.querySelector('.day-toggle');
    t.textContent = head.parentElement.classList.contains('open') ? '−' : '+';
  });
});

document.querySelectorAll('.day-num-big').forEach(n => {
  n.addEventListener('dblclick', e => {
    e.stopPropagation();
    n.parentElement.parentElement.classList.toggle('completed');
    const id = n.parentElement.parentElement.id;
    const done = JSON.parse(localStorage.getItem('aieng-done') || '{}');
    done[id] = n.parentElement.parentElement.classList.contains('completed');
    localStorage.setItem('aieng-done', JSON.stringify(done));
  });
});
const done = JSON.parse(localStorage.getItem('aieng-done') || '{}');
Object.entries(done).forEach(([id, isDone]) => {
  if (isDone) document.getElementById(id)?.classList.add('completed');
});

const navLinks = document.querySelectorAll('.nav-week a');
const days = document.querySelectorAll('.day');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const id = entry.target.id;
      navLinks.forEach(a => a.classList.toggle('active', a.getAttribute('href') === '#' + id));
    }
  });
}, { rootMargin: '-30% 0px -60% 0px' });
days.forEach(d => observer.observe(d));

window.addEventListener('load', () => {
  if (window.location.hash) {
    const target = document.querySelector(window.location.hash);
    if (target && target.classList.contains('day')) {
      target.classList.add('open');
      target.querySelector('.day-toggle').textContent = '−';
    }
  }
});

document.querySelectorAll('.sidebar a').forEach(a => {
  a.addEventListener('click', () => {
    document.querySelector('.sidebar').classList.remove('open');
  });
});
</script>
