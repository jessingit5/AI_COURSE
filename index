          <span class="resource-title">DeepSeek-R1 and GRPO explained</span>
          <span class="resource-source">Sebastian Raschka</span>
        </span>
        <span class="resource-arrow">→</span>
      </a>
        <a class="resource" href="https://www.youtube.com/watch?v=bAWV_yrqx4w" target="_blank" rel="noopener">
        <span class="resource-type video">video</span>
        <span class="resource-info">
          <span class="resource-title">GRPO from scratch (community)</span>
          <span class="resource-source">YouTube</span>
        </span>
        <span class="resource-arrow">→</span>
      </a>
        <a class="resource" href="https://huggingface.co/blog/rlhf" target="_blank" rel="noopener">
        <span class="resource-type article">article</span>
        <span class="resource-info">
          <span class="resource-title">RLHF: a beginner's intro</span>
          <span class="resource-source">Hugging Face Blog</span>
        </span>
        <span class="resource-arrow">→</span>
      </a>
