    <section class="week">
      <header class="week-header">
        <div class="week-num">03</div>
        <div class="week-info">
          <div class="week-tag">Week 3</div>
          <div class="week-title">Agents<br><span class="week-sub">From a single-call LLM to a tool-using, looping system.</span></div>
        </div>
